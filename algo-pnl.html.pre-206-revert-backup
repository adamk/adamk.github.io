  <script>
    function dollars(value) {
      return Number(value).toLocaleString("en-US", { style: "currency", currency: "USD" });
    }

    function pct(value) {
      if (value === null || value === undefined || Number.isNaN(Number(value))) return "-";
      return Number(value).toFixed(1) + "%";
    }

    fetch("/data/algo-pnl.json?v=" + Date.now(), { cache: "no-store" })
      .then(response => response.json())
      .then(data => {

      // Dynamic Main Stats
      const tradeStats = data.trade_stats || data.tradeStats || data.stats || {};
      const realizedAlgoPnl = tradeStats.realized_algo_pnl ?? data.realized_algo_pnl ?? data.realizedAlgoPnl ?? 0;
      const winRate = tradeStats.win_rate_pct ?? tradeStats.win_rate ?? data.win_rate ?? data.winRate ?? 0;
      const closedTrades = tradeStats.closed_trades ?? data.closed_trades ?? data.closedTrades ?? 0;
      const avgWin = tradeStats.avg_win ?? data.avg_win ?? data.avgWin ?? 0;
      const avgLoss = tradeStats.avg_loss ?? data.avg_loss ?? data.avgLoss ?? 0;


      const profitFactor =
        tradeStats.profit_factor ??
        data.profit_factor ??
        data.profitFactor ??
        null;

      const todayAccountPnl =
        tradeStats.today_account_pnl ??
        data.today_account_pnl ??
        data.todayAccountPnl ??
        data.account_today_pnl ??
        null;
const strategyStartingCapital = Number(
        data.strategy_starting_capital ?? 0
      );

      const realizedAlgoReturn =
        strategyStartingCapital > 0
          ? (Number(realizedAlgoPnl) / strategyStartingCapital) * 100
          : null;

      setTextIfExists("realized-algo-pnl", formatMoneyValue(realizedAlgoPnl));
      setTextIfExists("realizedAlgoPnl", formatMoneyValue(realizedAlgoPnl));

      setTextIfExists(
        "realizedAlgoReturn",
        realizedAlgoReturn === null
          ? "-"
          : realizedAlgoReturn.toFixed(2) + "%"
      );

      setTextIfExists("win-rate", formatPctValue(winRate));
      setTextIfExists("winRate", formatPctValue(winRate));

      setTextIfExists("closed-trades", String(closedTrades));
      setTextIfExists("closedTrades", String(closedTrades));

      setTextIfExists(
        "todayAccountPnl",
        todayAccountPnl === null
          ? "-"
          : formatMoneyValue(todayAccountPnl)
      );

      setTextIfExists(
        "profitFactor",
        profitFactor === null ||
        !Number.isFinite(Number(profitFactor))
          ? "-"
          : Number(profitFactor).toFixed(2)
      );

      const avgLossDisplay = avgLoss === null ? 0 : avgLoss;
      setTextIfExists("avg-win-loss", `${formatMoneyValue(avgWin)} / ${formatMoneyValue(avgLossDisplay)}`);
      setTextIfExists("avgWinLoss", `${formatMoneyValue(avgWin)} / ${formatMoneyValue(avgLossDisplay)}`);
        setTextIfExists("accountType", data.account_type || "Live account");
        document.getElementById("equity").textContent = dollars(data.current_equity);

        const stats = data.stats || {};
        document.getElementById("realizedPnl").textContent = dollars(stats.realized_algo_pnl || 0);
        document.getElementById("winRate").textContent = pct(stats.win_rate_pct);
        // closedTrades and avgWinLoss are handled by Dynamic Main Stats above.

        document.getElementById("updated").textContent =
          "Last updated: " + new Date(data.updated_at).toLocaleString();
        document.getElementById("note").textContent = data.note || "";

        const points = data.points || [];
        new Chart(document.getElementById("equityChart"), {
          type: "line",
          data: {
            labels: points.map(p => p.date),
            datasets: [{
              label: "Account Equity",
              data: points.map(p => p.equity),
              tension: 0.25,
              pointRadius: 2,
              borderColor: "#f4c430",
              backgroundColor: "rgba(244, 196, 48, 0.18)",
              pointBackgroundColor: "#f4c430",
              pointBorderColor: "#f4c430"
            }]
          },
          options: {
            responsive: true,
            plugins: {
              tooltip: { callbacks: { label: context => "Equity: " + dollars(context.parsed.y) } }
            },
            scales: {
              y: { ticks: { callback: value => "$" + Number(value).toLocaleString() } }
            }
          }
        });
      })
      .catch(() => {
        document.querySelector(".chart-box").innerHTML = "<p>Unable to load P&L data right now.</p>";
      });
  </script>

